window.addEventListener("load", () => {


const addButton = document.getElementById("addUpdateButton");
const creator = document.getElementById("updateCreator");
const cancelButton = document.getElementById("cancelUpdateButton");


if(!addButton || !creator || !cancelButton){

    console.log("Updates elements missing");
    return;

}



addButton.addEventListener("click", () => {

    creator.style.display = "block";

});



cancelButton.addEventListener("click", () => {

    creator.style.display = "none";

});



});
