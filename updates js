console.log("Updates JS loaded");


document.addEventListener("click", function(e){


    if(e.target && e.target.id === "addUpdateButton"){

        const creator =
        document.getElementById("updateCreator");


        if(creator){

            creator.style.display = "block";

        }

    }



    if(e.target && e.target.id === "cancelUpdateButton"){

        const creator =
        document.getElementById("updateCreator");


        if(creator){

            creator.style.display = "none";

        }

    }


});
