console.log("Updates JS loaded");


document.addEventListener("DOMContentLoaded", () => {


const addUpdateButton =
document.getElementById("addUpdateButton");


const updateCreator =
document.getElementById("updateCreator");


const cancelUpdateButton =
document.getElementById("cancelUpdateButton");



if(addUpdateButton && updateCreator){

    addUpdateButton.onclick = () => {

        updateCreator.style.display = "block";

    };

}



if(cancelUpdateButton && updateCreator){

    cancelUpdateButton.onclick = () => {

        updateCreator.style.display = "none";

    };

}


});
